subscription_id     = "cf1c38f8-e95a-4919-ba4f-d9a9183480a9"
location            = "southeastasia"
resource_group_name = "ctse-group"
aks_cluster_name    = "ctse-cluster"
dns_prefix          = "ctse"
node_count          = 2
vm_size             = "Standard_B2s"

dockerhub_username  = "praveen1214"
# Recommended immutable tag: git short SHA (generated by infra/push-images.ps1)
image_tag           = "replace_with_git_sha"

cors_origin         = "*"

# Replace with secure values before apply.
jwt_secret          = "replace_with_strong_secret_min_32_chars"
auth_mongo_uri      = "mongodb+srv://user:pass@cluster.mongodb.net/auth_db"
product_mongo_uri   = "mongodb+srv://user:pass@cluster.mongodb.net/product_db"
order_mongo_uri     = "mongodb+srv://user:pass@cluster.mongodb.net/order_db"
delivery_mongo_uri  = "mongodb+srv://user:pass@cluster.mongodb.net/delivery_db"
