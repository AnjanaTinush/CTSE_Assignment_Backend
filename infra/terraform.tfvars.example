subscription_id     = "<azure-subscription-id>"
location            = "southeastasia"
resource_group_name = "ctse-group"
aks_cluster_name    = "ctse-cluster"
dns_prefix          = "ctse"
node_count          = 2
vm_size             = "Standard_B2s"

dockerhub_username  = "<dockerhub-username>"
# Recommended immutable tag: git short SHA (generated by infra/push-images.ps1)
image_tag           = "replace_with_git_sha"

cors_origin         = "https://your-frontend.example.com"

# Replace with secure values before apply.
jwt_secret             = "<replace-with-strong-random-jwt-secret>"
internal_service_token = "<replace-with-strong-random-internal-token>"
auth_mongo_uri         = "<mongodb-uri-for-auth-service>"
product_mongo_uri      = "<mongodb-uri-for-product-service>"
order_mongo_uri        = "<mongodb-uri-for-order-service>"
delivery_mongo_uri     = "<mongodb-uri-for-delivery-service>"
